rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny (Safety Net)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // System connectivity test
    match /system/connection_test {
      allow read: if true;
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
    }

    // Restaurants
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow write: if isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'restaurant';
    }

    // Menu items
    match /restaurants/{restaurantId}/menu/{productId} {
      allow read: if true;
      allow write: if isSignedIn() && 
        get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerId == request.auth.uid;
    }

    // Orders
    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.restaurantId == request.auth.uid ||
        resource.data.riderId == request.auth.uid
      );
      allow update: if isSignedIn() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'riderId'])
      );
    }

    // Default deny (Safety Net)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

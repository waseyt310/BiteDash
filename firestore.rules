rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny ALL at the top (OR logic in Firestore means more specific rules will still match)
    // Actually, catch-all at the top is safer as a starting point.
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
    }

    // Restaurants
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Menu items
    match /restaurants/{restaurantId}/menu/{productId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Orders
    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.restaurantId == request.auth.uid ||
        resource.data.riderId == request.auth.uid
      );
      allow update: if isSignedIn();
    }
    
    // Grocery and Exclusives
    match /grocery_categories/{categoryId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /groceries/{productId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /exclusives/{dealId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // System connectivity test
    match /system/connection_test {
      allow read: if true;
    }
    match /test/connection {
      allow read: if true;
    }
  }
}

{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user with role-based access",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "restaurant", "rider", "admin"] },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Restaurant": {
      "title": "Restaurant",
      "description": "Food establishment profile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "rating": { "type": "number" },
        "image": { "type": "string" },
        "address": { "type": "string" },
        "location": { "type": "object" },
        "openingHours": { "type": "object" },
        "isOpen": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "name", "category"]
    },
    "Product": {
      "title": "Product",
      "description": "Menu item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "restaurantId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "isAvailable": { "type": "boolean" },
        "customization": { "type": "array" }
      },
      "required": ["restaurantId", "name", "price"]
    },
    "Order": {
      "title": "Order",
      "description": "Order details and status",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "restaurantId": { "type": "string" },
        "riderId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "accepted", "preparing", "ready", "picked_up", "on_the_way", "delivered", "cancelled"] },
        "deliveryAddress": { "type": "string" },
        "deliveryLocation": { "type": "object" },
        "paymentMethod": { "type": "string" },
        "paymentStatus": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "restaurantId", "items", "total", "status"]
    },
    "GroceryCategory": {
      "title": "Grocery Category",
      "description": "Category for grocery items",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" }
      }
    },
    "GroceryProduct": {
      "title": "Grocery Product",
      "description": "Individual grocery item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "unit": { "type": "string" },
        "image": { "type": "string" },
        "inStock": { "type": "boolean" },
        "deliveryEta": { "type": "string" }
      }
    },
    "ExclusiveDeal": {
      "title": "Exclusive Deal",
      "description": "Premium deal or item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "discount": { "type": "number" },
        "rating": { "type": "number" },
        "reviews": { "type": "number" },
        "endsAt": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/restaurants/{restaurantId}": {
      "schema": "Restaurant",
      "description": "Restaurant details"
    },
    "/restaurants/{restaurantId}/menu/{productId}": {
      "schema": "Product",
      "description": "Menu items for a restaurant"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Platform orders"
    },
    "/grocery_categories/{categoryId}": {
      "schema": "GroceryCategory",
      "description": "Grocery categories"
    },
    "/groceries/{productId}": {
      "schema": "GroceryProduct",
      "description": "Grocery products"
    },
    "/exclusives/{dealId}": {
      "schema": "ExclusiveDeal",
      "description": "Exclusive deals and premium items"
    }
  }
}
